# Dependencies — rebuilt inside image
**/node_modules
**/.npm

# Build outputs — rebuilt inside image
client/dist
client/build
server/dist

# Environment & secrets — never ship
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Git
.git
.gitignore
.gitattributes

# Editor / OS
.DS_Store
.idea
.vscode
*.swp
*.swo
Thumbs.db

# Test / CI artifacts
coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local dev databases
*.db
*.db-journal
server/prisma/test.db
server/prisma/dev.db

# Documentation / misc (reduces image size + build cache invalidation)
README.md
Idea.md
auto_commit.js

# Docker files themselves
Dockerfile
docker-compose*.yml
.dockerignore
