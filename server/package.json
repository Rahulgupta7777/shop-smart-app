{
  "name": "shopsmart-backend",
  "version": "1.0.0",
  "description": "Backend API for Moji",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "npx prisma generate --schema=./prisma/test.prisma >/dev/null 2>&1 && DATABASE_URL=file:./prisma/test.db npx prisma db push --schema=./prisma/test.prisma --accept-data-loss --skip-generate >/dev/null 2>&1; DATABASE_URL=file:./prisma/test.db jest --forceExit --detectOpenHandles --runInBand",
    "test:ci": "npm test -- --ci",
    "lint": "echo 'No linter configured yet'",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.12.0",
    "@supabase/supabase-js": "^2.43.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "replicate": "^0.30.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.0",
    "supertest": "^6.3.4"
  }
}
